{
  "manifest_version": 3,
  "name": "Liquid Forest New Tab",
  "version": "1.0",
  "description": "Custom new tab with forest background",

  "chrome_url_overrides": {
    "newtab": "newtab.html"
  },

  "browser_specific_settings": {
    "gecko": {
      "id": "liquid-forest-newtab@halo"
    }
  },

  "data_collection_permissions": {
    "required": false
  }
}
